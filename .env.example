# Database (RAG for chat + Insights studio HTML posts)
DATABASE_URL=

# Insights studio — /studio/blog (password + optional stronger session secret)
# Demo / meeting: use a simple value locally; set a strong secret in Vercel for production.
CLIENT_STUDIO_PASSWORD=demo-studio-meeting
# Optional; if unset, a derived secret is used from CLIENT_STUDIO_PASSWORD (set explicitly in production).
CLIENT_STUDIO_SESSION_SECRET=

# Supabase (CRM – Phase 1). Get from Supabase project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (chat + RAG embeddings)
OPENAI_API_KEY=

# HubSpot (contact form sync)
HUBSPOT_ACCESS_TOKEN=
# or: HUBSPOT_PRIVATE_APP_TOKEN=

# Trigger.dev (PDF-after-contact; set in Next.js)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=as-brokers

# App URL (PDF worker + draft mode)
NEXT_PUBLIC_APP_URL=
# or set APP_URL in Trigger worker env

# Resend (set in Trigger.dev worker env, not just Next.js)
RESEND_API_KEY=
RESEND_FROM=

# Sanity (Phase 3)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3000/studio
SANITY_VIEWER_TOKEN=

# Analytics (Phase 4) – only loaded after "Accept All" cookie consent (POPIA)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_HOTJAR_ID=
